# ── Vercel 環境變數（Project Settings → Environment Variables 設定，勿 commit .env）──

# 後台管理密碼（自訂，登入後台與存檔/上傳都會用到）
ADMIN_PASSWORD=

# GitHub Fine-grained Personal Access Token
# 建立：GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# 權限：對本 repo 的 Contents = Read and write
GITHUB_PAT=

# 你的 GitHub 帳號與 repo 名稱
GITHUB_OWNER=erinnsama
GITHUB_REPO=ririkabio
